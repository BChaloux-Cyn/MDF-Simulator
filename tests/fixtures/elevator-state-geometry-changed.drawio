                <mxCell id="elevator:state:Elevator:Stopping" value="Stopping&lt;br&gt;──────────────────&lt;br&gt;&lt;i&gt;entry /&lt;/i&gt;&lt;br&gt;self.direction = Stopped;&lt;br&gt;select any shaft related by self-&amp;gt;R11;&lt;br&gt;generate Stop to shaft;" style="rounded=1;whiteSpace=wrap;html=1;arcSize=10;fontFamily=Courier New;" parent="1" vertex="1">
                    <mxGeometry x="619" y="1237" width="273" height="120" as="geometry"/>
