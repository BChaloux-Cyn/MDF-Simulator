                <mxCell id="elevator:state:Elevator:At_Floor" value="At_Floor&lt;br&gt;──────────────────&lt;br&gt;&lt;i&gt;entry /&lt;/i&gt;&lt;br&gt;select any next_req from instances of Request where request_id == self.r14_request_id;&lt;br&gt;if (next_req != empty) {&lt;br&gt;  if (next_req.destination_floor &amp;gt; self.current_floor) { self.next_direction = Up; }&lt;br&gt;  if (next_req.destination_floor &amp;lt; self.current_floor) { self.next_direction = Down; }&lt;br&gt;} else {&lt;br&gt;  select any fc from instances of FloorCall where floor_num == self.current_floor;&lt;br&gt;  if (fc != empty) { self.next_direction = fc.direction; }&lt;br&gt;  else { self.next_direction = Stopped; }&lt;br&gt;}&lt;br&gt;select any floor_inst from instances of Floor where floor_num == self.current_floor;&lt;br&gt;select any indicator related by self-&amp;gt;R10;&lt;br&gt;generate Direction_set(direction: self.next_direction) to indicator;&lt;br&gt;generate Elevator_arrived to floor_inst;&lt;br&gt;generate Open_door to self;" style="rounded=1;whiteSpace=wrap;html=1;arcSize=10;fontFamily=Courier New;" parent="1" vertex="1">
