        <mxCell id="elevator:state:Elevator:__initial__" value="" style="ellipse;whiteSpace=wrap;html=1;aspect=fixed;fillColor=#000000;strokeColor=#000000;" vertex="1" parent="1">
          <mxGeometry x="1651" y="120" width="20" height="20" as="geometry"/>
        </mxCell>
        <mxCell id="elevator:state:Elevator:Idle" value="Idle&lt;br&gt;──────────────────&lt;br&gt;&lt;i&gt;entry /&lt;/i&gt;&lt;br&gt;select any req related by self-&amp;gt;R2;&lt;br&gt;if (req != empty) { generate Door_closed to req; }&lt;br&gt;self.direction = Stopped;&lt;br&gt;self.next_stop_floor = 0;&lt;br&gt;select any req from instances of Request where request_id == self.r14_request_id;&lt;br&gt;if (req != empty) {&lt;br&gt;  generate Request_assigned(target_floor: req.destination_floor) to self;&lt;br&gt;} else {&lt;br&gt;  select any disp from instances of Dispatcher;&lt;br&gt;  generate Elevator_available(queue_length: 0) to disp;&lt;br&gt;}" style="rounded=1;whiteSpace=wrap;html=1;arcSize=10;fontFamily=Courier New;" vertex="1" parent="1">
          <mxGeometry x="1250" y="504" width="583" height="280" as="geometry"/>
        </mxCell>
        <mxCell id="elevator:state:Elevator:Moving_Up" value="Moving_Up&lt;br&gt;──────────────────&lt;br&gt;&lt;i&gt;entry /&lt;/i&gt;&lt;br&gt;self.next_stop_floor = rcvd_evt.target_floor;&lt;br&gt;self.current_floor = rcvd_evt.current_floor;&lt;br&gt;self.direction = Up;&lt;br&gt;select any shaft related by self-&amp;gt;R11;&lt;br&gt;generate Move_up to shaft;" style="rounded=1;whiteSpace=wrap;html=1;arcSize=10;fontFamily=Courier New;" vertex="1" parent="1">
          <mxGeometry x="644" y="818" width="324" height="160" as="geometry"/>
        </mxCell>
        <mxCell id="elevator:state:Elevator:Moving_Down" value="Moving_Down&lt;br&gt;──────────────────&lt;br&gt;&lt;i&gt;entry /&lt;/i&gt;&lt;br&gt;self.next_stop_floor = rcvd_evt.target_floor;&lt;br&gt;self.current_floor = rcvd_evt.current_floor;&lt;br&gt;self.direction = Down;&lt;br&gt;select any shaft related by self-&amp;gt;R11;&lt;br&gt;generate Move_down to shaft;" style="rounded=1;whiteSpace=wrap;html=1;arcSize=10;fontFamily=Courier New;" vertex="1" parent="1">
          <mxGeometry x="1103" y="1326" width="324" height="160" as="geometry"/>
        </mxCell>
        <mxCell id="elevator:state:Elevator:Stopping" value="Stopping&lt;br&gt;──────────────────&lt;br&gt;&lt;i&gt;entry /&lt;/i&gt;&lt;br&gt;self.current_floor = rcvd_evt.current_floor;&lt;br&gt;self.direction = Stopped;&lt;br&gt;select any shaft related by self-&amp;gt;R11;&lt;br&gt;generate Stop to shaft;" style="rounded=1;whiteSpace=wrap;html=1;arcSize=10;fontFamily=Courier New;" vertex="1" parent="1">
          <mxGeometry x="472" y="1262" width="316" height="140" as="geometry"/>
        </mxCell>
        <mxCell id="elevator:state:Elevator:At_Floor" value="At_Floor&lt;br&gt;──────────────────&lt;br&gt;&lt;i&gt;entry /&lt;/i&gt;&lt;br&gt;select any next_req from instances of Request where request_id == self.r14_request_id;&lt;br&gt;if (next_req != empty) {&lt;br&gt;  if (next_req.destination_floor &amp;gt; self.current_floor) { self.next_direction = Up; }&lt;br&gt;  if (next_req.destination_floor &amp;lt; self.current_floor) { self.next_direction = Down; }&lt;br&gt;} else {&lt;br&gt;  select any fc from instances of FloorCall where floor_num == self.current_floor;&lt;br&gt;  if (fc != empty) { self.next_direction = fc.direction; }&lt;br&gt;  else { self.next_direction = Stopped; }&lt;br&gt;}&lt;br&gt;select any floor_inst from instances of Floor where floor_num == self.current_floor;&lt;br&gt;select any indicator related by self-&amp;gt;R10;&lt;br&gt;generate Direction_set(direction: self.next_direction) to indicator;&lt;br&gt;generate Elevator_arrived to floor_inst;&lt;br&gt;generate Open_door to self;" style="rounded=1;whiteSpace=wrap;html=1;arcSize=10;fontFamily=Courier New;" vertex="1" parent="1">
          <mxGeometry x="120" y="378" width="619" height="340" as="geometry"/>
        </mxCell>
