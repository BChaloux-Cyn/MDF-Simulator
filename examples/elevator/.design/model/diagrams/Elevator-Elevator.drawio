        <mxCell id="elevator:trans:Elevator:Exchanging:Door_closed:8" value="elevator:trans:Elevator:Exchanging:Door_closed:8&lt;br&gt;Door_closed()&lt;br&gt;[self.next_stop_floor == self.current_floor]" style="edgeStyle=orthogonalEdgeStyle;html=1;labelBackgroundColor=none;exitX=1.0;exitY=0.5;exitDx=0;exitDy=0;entryX=0.0;entryY=0.3333;entryDx=0;entryDy=0;" edge="1" source="elevator:state:Elevator:Exchanging" target="elevator:state:Elevator:Idle" parent="1">
          <mxGeometry x="-0.3" y="-15" relative="1" as="geometry"/>
