        <mxCell id="elevator:trans:Elevator:Exchanging:Door_closed:7" value="elevator:trans:Elevator:Exchanging:Door_closed:7&lt;br&gt;Door_closed()&lt;br&gt;[self.next_stop_floor != self.current_floor]" style="edgeStyle=orthogonalEdgeStyle;html=1;labelBackgroundColor=none;exitX=0.5;exitY=1.0;exitDx=0;exitDy=0;entryX=0.3333;entryY=0.0;entryDx=0;entryDy=0;" edge="1" source="elevator:state:Elevator:Exchanging" target="elevator:state:Elevator:Departing" parent="1">
