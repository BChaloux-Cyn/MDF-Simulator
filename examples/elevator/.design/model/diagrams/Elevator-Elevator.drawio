                </mxCell>
                <mxCell id="elevator:state:Elevator:Departing" value="Departing&lt;br&gt;──────────────────&lt;br&gt;&lt;i&gt;entry /&lt;/i&gt;&lt;br&gt;if (self.next_stop_floor &amp;gt; self.current_floor) {&lt;br&gt;    self.direction = Up;&lt;br&gt;} else {&lt;br&gt;    self.direction = Down;&lt;br&gt;}&lt;br&gt;generate Ready to self;&lt;br&gt;" style="rounded=1;whiteSpace=wrap;html=1;arcSize=10;fontFamily=Courier New;" parent="1" vertex="1">
                    <mxGeometry x="1510" y="1900" width="345" height="200" as="geometry"/>
                </mxCell>
                <mxCell id="elevator:state:Elevator:Moving" value="Moving" style="rounded=1;whiteSpace=wrap;html=1;arcSize=10;fontFamily=Courier New;" parent="1" vertex="1">
                    <mxGeometry x="2210" y="2359" width="160" height="50" as="geometry"/>
                </mxCell>
                <mxCell id="elevator:state:Elevator:Floor_Updating" value="Floor_Updating&lt;br&gt;──────────────────&lt;br&gt;&lt;i&gt;entry /&lt;/i&gt;&lt;br&gt;self.current_floor = rcvd_evt.floor_num;&lt;br&gt;if (self.current_floor == self.next_stop_floor) {&lt;br&gt;    generate At_Destination to self;&lt;br&gt;} else {&lt;br&gt;    generate Continue to self;&lt;br&gt;}&lt;br&gt;" style="rounded=1;whiteSpace=wrap;html=1;arcSize=10;fontFamily=Courier New;" parent="1" vertex="1">
                    <mxGeometry x="2870" y="2056" width="352" height="200" as="geometry"/>
                </mxCell>
                <mxCell id="elevator:state:Elevator:Arriving" value="Arriving&lt;br&gt;──────────────────&lt;br&gt;&lt;i&gt;entry /&lt;/i&gt;&lt;br&gt;// Save previous travel direction before clearing&lt;br&gt;Direction prev_direction = self.direction;&lt;br&gt;self.direction = None;&lt;br&gt;FloorNumber my_floor = self.current_floor;&lt;br&gt;UniqueID my_id = self.elevator_id;&lt;br&gt;&lt;br&gt;// Notify all DestFloorButtons — current floor&amp;#x27;s button transitions Lit→Idle&lt;br&gt;// (async: hasn&amp;#x27;t fired yet when we check below, but current floor is excluded&lt;br&gt;// by the != my_floor filter so it doesn&amp;#x27;t matter)&lt;br&gt;select many buttons related by self-&amp;gt;R4;&lt;br&gt;generate Floor_served(floor_num: my_floor) to buttons;&lt;br&gt;&lt;br&gt;// Collect all lit DestFloorButtons for this elevator (excluding current&lt;br&gt;// floor, which was just served), sorted ascending by floor number&lt;br&gt;select many lit_btns from instances of DestFloorButton&lt;br&gt;    where self.r4_elevator_id == my_id&lt;br&gt;    and self.curr_state == Lit&lt;br&gt;    and self.r5_floor_num != my_floor&lt;br&gt;    order by self.r5_floor_num ascending;&lt;br&gt;&lt;br&gt;if (cardinality lit_btns == 0) {&lt;br&gt;    // Priorities 3-4: FloorCallButton logic deferred until Dispatcher&lt;br&gt;    // Priority 5: No work — go Idle when door closes&lt;br&gt;    self.next_stop_floor = my_floor;&lt;br&gt;    generate Arrived to self;&lt;br&gt;    return;&lt;br&gt;}&lt;br&gt;&lt;br&gt;DestFloorButton first_btn = first of lit_btns;&lt;br&gt;DestFloorButton last_btn = last of lit_btns;&lt;br&gt;&lt;br&gt;// Priority 1: Continue in same direction if lit buttons exist that way&lt;br&gt;if (prev_direction == Down and first_btn.r5_floor_num &amp;lt; my_floor) {&lt;br&gt;    // Lit buttons below — continue down to nearest&lt;br&gt;    select many below_btns from instances of DestFloorButton&lt;br&gt;        where self.r4_elevator_id == my_id&lt;br&gt;        and self.curr_state == Lit&lt;br&gt;        and self.r5_floor_num &amp;lt; my_floor&lt;br&gt;        order by self.r5_floor_num descending;&lt;br&gt;    self.next_stop_floor = (first of below_btns).r5_floor_num;&lt;br&gt;} else if (prev_direction == Up and last_btn.r5_floor_num &amp;gt; my_floor) {&lt;br&gt;    // Lit buttons above — continue up to nearest&lt;br&gt;    select many above_btns from instances of DestFloorButton&lt;br&gt;        where self.r4_elevator_id == my_id&lt;br&gt;        and self.curr_state == Lit&lt;br&gt;        and self.r5_floor_num &amp;gt; my_floor&lt;br&gt;        order by self.r5_floor_num ascending;&lt;br&gt;    self.next_stop_floor = (first of above_btns).r5_floor_num;&lt;br&gt;} else {&lt;br&gt;    // Priority 2: Reverse — all lit buttons are in opposite direction&lt;br&gt;    // In a sorted ascending list, first_btn is nearest above and&lt;br&gt;    // last_btn is nearest below when all are on one side&lt;br&gt;    if (first_btn.r5_floor_num &amp;gt; my_floor) {&lt;br&gt;        self.next_stop_floor = first_btn.r5_floor_num;&lt;br&gt;    } else {&lt;br&gt;        self.next_stop_floor = last_btn.r5_floor_num;&lt;br&gt;    }&lt;br&gt;}&lt;br&gt;&lt;br&gt;generate Arrived to self;&lt;br&gt;" style="rounded=1;whiteSpace=wrap;html=1;arcSize=10;fontFamily=Courier New;" parent="1" vertex="1">
                    <mxGeometry x="2140" y="650" width="561" height="980" as="geometry"/>
                </mxCell>
