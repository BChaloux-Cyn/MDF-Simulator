        <mxCell id="elevator:state:Elevator:Departing" value="Departing&lt;br&gt;──────────────────&lt;br&gt;&lt;i&gt;entry /&lt;/i&gt;&lt;br&gt;if (self.next_stop_floor &amp;gt; self.current_floor) {&lt;br&gt;    self.direction = Up;&lt;br&gt;} else {&lt;br&gt;    self.direction = Down;&lt;br&gt;}&lt;br&gt;generate Ready to self;&lt;br&gt;" style="rounded=1;whiteSpace=wrap;html=1;arcSize=10;fontFamily=Courier New;" vertex="1" parent="1">
          <mxGeometry x="1257" y="1848" width="345" height="200" as="geometry"/>
        </mxCell>
        <mxCell id="elevator:state:Elevator:Moving" value="Moving" style="rounded=1;whiteSpace=wrap;html=1;arcSize=10;fontFamily=Courier New;" vertex="1" parent="1">
          <mxGeometry x="1940" y="2597" width="160" height="50" as="geometry"/>
        </mxCell>
        <mxCell id="elevator:state:Elevator:Floor_Updating" value="Floor_Updating&lt;br&gt;──────────────────&lt;br&gt;&lt;i&gt;entry /&lt;/i&gt;&lt;br&gt;self.current_floor = rcvd_evt.floor_num;&lt;br&gt;if (self.current_floor == self.next_stop_floor) {&lt;br&gt;    generate At_Destination to self;&lt;br&gt;} else {&lt;br&gt;    generate Continue to self;&lt;br&gt;}&lt;br&gt;" style="rounded=1;whiteSpace=wrap;html=1;arcSize=10;fontFamily=Courier New;" vertex="1" parent="1">
          <mxGeometry x="2944" y="2828" width="352" height="200" as="geometry"/>
        </mxCell>
        <mxCell id="elevator:state:Elevator:Arriving" value="Arriving&lt;br&gt;──────────────────&lt;br&gt;&lt;i&gt;entry /&lt;/i&gt;&lt;br&gt;Direction prev_direction = self.direction;&lt;br&gt;self.direction = None;&lt;br&gt;&lt;br&gt;// Find lit DestFloorButtons (excluding current floor)&lt;br&gt;Set&amp;lt;DestFloorButton&amp;gt; lit_btns = self._get_lit_buttons();&lt;br&gt;&lt;br&gt;if (lit_btns.is_empty()) {&lt;br&gt;    // No destination buttons — check for lit FloorCallButtons&lt;br&gt;    Set&amp;lt;ShaftFloor&amp;gt; shaft_floors = select many related by self-&amp;gt;R1-&amp;gt;R2;&lt;br&gt;    Set&amp;lt;FloorCallButton&amp;gt; lit_calls = shaft_floors.flat_map(&lt;br&gt;        [] |sf: ShaftFloor| -&amp;gt; Set&amp;lt;FloorCallButton&amp;gt; {&lt;br&gt;            Floor f = sf-&amp;gt;R3;&lt;br&gt;            return select many related by f-&amp;gt;R6&lt;br&gt;                where [] |btn: FloorCallButton| -&amp;gt; Boolean {&lt;br&gt;                    return btn.curr_state == Lit;&lt;br&gt;                };&lt;br&gt;        });&lt;br&gt;&lt;br&gt;    if (lit_calls.is_empty()) {&lt;br&gt;        // No work at all — go Idle when door closes&lt;br&gt;        self.next_stop_floor = self.current_floor;&lt;br&gt;        generate Arrived to self;&lt;br&gt;        return;&lt;br&gt;    }&lt;br&gt;&lt;br&gt;    // Pick the earliest pressed FloorCallButton&lt;br&gt;    List&amp;lt;FloorCallButton&amp;gt; sorted_calls = lit_calls.sort(&lt;br&gt;        [] |a: FloorCallButton, b: FloorCallButton| -&amp;gt; Boolean {&lt;br&gt;            return a.pressed_at &amp;lt; b.pressed_at;&lt;br&gt;        });&lt;br&gt;    FloorCallButton earliest = sorted_calls.peek_front();&lt;br&gt;    Floor target_floor = earliest-&amp;gt;R6;&lt;br&gt;    self.next_stop_floor = target_floor.floor_num;&lt;br&gt;    generate Arrived to self;&lt;br&gt;    return;&lt;br&gt;}&lt;br&gt;&lt;br&gt;self.next_stop_floor = self._pick_next_stop(lit_btns, prev_direction);&lt;br&gt;generate Arrived to self;&lt;br&gt;" style="rounded=1;whiteSpace=wrap;html=1;arcSize=10;fontFamily=Courier New;" vertex="1" parent="1">
          <mxGeometry x="4318" y="1244" width="511" height="860" as="geometry"/>
        </mxCell>
        <mxCell id="elevator:state:Elevator:Exchanging" value="Exchanging&lt;br&gt;──────────────────&lt;br&gt;&lt;i&gt;entry /&lt;/i&gt;&lt;br&gt;// Find the specific DestFloorButton for the current floor and notify it&lt;br&gt;Set&amp;lt;DestFloorButton&amp;gt; dest_buttons = select many related by self-&amp;gt;R4&lt;br&gt;    where [self.current_floor] |btn: DestFloorButton| -&amp;gt; Boolean {&lt;br&gt;        Floor f = btn-&amp;gt;R5;&lt;br&gt;        return btn.curr_state == Lit and f.floor_num == self.current_floor;&lt;br&gt;    };&lt;br&gt;generate Floor_served to dest_buttons;&lt;br&gt;&lt;br&gt;// Notify FloorCallButtons at current floor — transitions Lit-&amp;gt;Idle&lt;br&gt;Set&amp;lt;ShaftFloor&amp;gt; shaft_floors = select many related by self-&amp;gt;R1-&amp;gt;R2;&lt;br&gt;Set&amp;lt;ShaftFloor&amp;gt; current_sf = shaft_floors.filter(&lt;br&gt;    [self.current_floor] |s: ShaftFloor| -&amp;gt; Boolean {&lt;br&gt;        Floor f = s-&amp;gt;R3;&lt;br&gt;        return f.floor_num == self.current_floor;&lt;br&gt;    });&lt;br&gt;ShaftFloor sf = current_sf.peek_front();&lt;br&gt;Floor floor = sf-&amp;gt;R3;&lt;br&gt;Set&amp;lt;FloorCallButton&amp;gt; call_buttons = select many related by floor-&amp;gt;R6&lt;br&gt;    where [] |btn: FloorCallButton| -&amp;gt; Boolean {&lt;br&gt;        return btn.curr_state == Lit;&lt;br&gt;    };&lt;br&gt;generate Call_served to call_buttons;&lt;br&gt;&lt;br&gt;// Open the car door — it will open the paired shaft door&lt;br&gt;CarDoor car_door = self-&amp;gt;R7;&lt;br&gt;generate Open_cmd to car_door;&lt;br&gt;" style="rounded=1;whiteSpace=wrap;html=1;arcSize=10;fontFamily=Courier New;" vertex="1" parent="1">
          <mxGeometry x="1842" y="120" width="540" height="600" as="geometry"/>
        </mxCell>
