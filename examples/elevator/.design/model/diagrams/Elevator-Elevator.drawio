        <mxCell id="elevator:state:Elevator:Departing" value="Departing&lt;br&gt;──────────────────&lt;br&gt;&lt;i&gt;entry /&lt;/i&gt;&lt;br&gt;self.next_stop_floor = rcvd_evt.floor_num;&lt;br&gt;if (self.next_stop_floor &amp;gt; self.current_floor) {&lt;br&gt;    self.direction = Up;&lt;br&gt;} else {&lt;br&gt;    self.direction = Down;&lt;br&gt;}&lt;br&gt;generate Ready to self;&lt;br&gt;" style="rounded=1;whiteSpace=wrap;html=1;arcSize=10;fontFamily=Courier New;" vertex="1" parent="1">
          <mxGeometry x="2499" y="1526" width="345" height="220" as="geometry"/>
