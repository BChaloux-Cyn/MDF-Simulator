        <mxCell id="elevator:method:Elevator:_get_lit_buttons" value="&lt;b&gt;- _get_lit_buttons(): Set&amp;lt;DestFloorButton&amp;gt;&lt;/b&gt;&lt;br&gt;──────────────────&lt;br&gt;FloorNumber my_floor = self.current_floor;&lt;br&gt;Set&amp;lt;DestFloorButton&amp;gt; lit = select many related by self-&amp;gt;R4&lt;br&gt;    where [my_floor] |btn: DestFloorButton| -&amp;gt; Boolean {&lt;br&gt;        Floor floor = btn-&amp;gt;R5;&lt;br&gt;        return btn.curr_state == Lit&lt;br&gt;            and floor.floor_num != my_floor;&lt;br&gt;    };&lt;br&gt;return lit;&lt;br&gt;" style="rounded=0;whiteSpace=wrap;html=1;align=left;verticalAlign=top;fontFamily=Courier New;fontSize=11;fillColor=#f5f5f5;strokeColor=#666666;fontColor=#333333;spacingLeft=6;spacingRight=6;spacingTop=4;spacingBottom=4;" vertex="1" parent="1">
          <mxGeometry x="3436" y="120" width="400" height="210" as="geometry"/>
        </mxCell>
        <mxCell id="elevator:method:Elevator:_pick_next_stop" value="&lt;b&gt;- _pick_next_stop(lit_btns: Set&amp;lt;DestFloorButton&amp;gt;, prev_direction: Direction): FloorNumber&lt;/b&gt;&lt;br&gt;──────────────────&lt;br&gt;FloorNumber my_floor = self.current_floor;&lt;br&gt;&lt;br&gt;// Sort ascending by floor number (traverse R5 to get floor_num)&lt;br&gt;List&amp;lt;DestFloorButton&amp;gt; sorted_btns = lit_btns.sort(&lt;br&gt;    [] |a: DestFloorButton, b: DestFloorButton| -&amp;gt; Boolean {&lt;br&gt;        Floor a_floor = a-&amp;gt;R5;&lt;br&gt;        Floor b_floor = b-&amp;gt;R5;&lt;br&gt;        return a_floor.floor_num &amp;lt; b_floor.floor_num;&lt;br&gt;    });&lt;br&gt;DestFloorButton first_btn = sorted_btns.peek_front();&lt;br&gt;DestFloorButton last_btn = sorted_btns.peek_back();&lt;br&gt;Floor first_floor = first_btn-&amp;gt;R5;&lt;br&gt;Floor last_floor = last_btn-&amp;gt;R5;&lt;br&gt;&lt;br&gt;// Priority 1: Continue in same direction if lit buttons exist that way&lt;br&gt;if (prev_direction == Down and first_floor.floor_num &amp;lt; my_floor) {&lt;br&gt;    List&amp;lt;DestFloorButton&amp;gt; below_sorted = lit_btns.filter(&lt;br&gt;        [my_floor] |b: DestFloorButton| -&amp;gt; Boolean {&lt;br&gt;            Floor f = b-&amp;gt;R5;&lt;br&gt;            return f.floor_num &amp;lt; my_floor;&lt;br&gt;        }).sort(&lt;br&gt;        [] |a: DestFloorButton, b: DestFloorButton| -&amp;gt; Boolean {&lt;br&gt;            Floor a_floor = a-&amp;gt;R5;&lt;br&gt;            Floor b_floor = b-&amp;gt;R5;&lt;br&gt;            return a_floor.floor_num &amp;gt; b_floor.floor_num;&lt;br&gt;        });&lt;br&gt;    DestFloorButton nearest = below_sorted.peek_front();&lt;br&gt;    Floor nearest_floor = nearest-&amp;gt;R5;&lt;br&gt;    return nearest_floor.floor_num;&lt;br&gt;} else if (prev_direction == Up and last_floor.floor_num &amp;gt; my_floor) {&lt;br&gt;    List&amp;lt;DestFloorButton&amp;gt; above_sorted = lit_btns.filter(&lt;br&gt;        [my_floor] |b: DestFloorButton| -&amp;gt; Boolean {&lt;br&gt;            Floor f = b-&amp;gt;R5;&lt;br&gt;            return f.floor_num &amp;gt; my_floor;&lt;br&gt;        }).sort(&lt;br&gt;        [] |a: DestFloorButton, b: DestFloorButton| -&amp;gt; Boolean {&lt;br&gt;            Floor a_floor = a-&amp;gt;R5;&lt;br&gt;            Floor b_floor = b-&amp;gt;R5;&lt;br&gt;            return a_floor.floor_num &amp;lt; b_floor.floor_num;&lt;br&gt;        });&lt;br&gt;    DestFloorButton nearest = above_sorted.peek_front();&lt;br&gt;    Floor nearest_floor = nearest-&amp;gt;R5;&lt;br&gt;    return nearest_floor.floor_num;&lt;br&gt;}&lt;br&gt;&lt;br&gt;// Priority 2: Reverse — all lit buttons are in opposite direction&lt;br&gt;if (first_floor.floor_num &amp;gt; my_floor) {&lt;br&gt;    return first_floor.floor_num;&lt;br&gt;}&lt;br&gt;return last_floor.floor_num;&lt;br&gt;" style="rounded=0;whiteSpace=wrap;html=1;align=left;verticalAlign=top;fontFamily=Courier New;fontSize=11;fillColor=#f5f5f5;strokeColor=#666666;fontColor=#333333;spacingLeft=6;spacingRight=6;spacingTop=4;spacingBottom=4;" vertex="1" parent="1">
          <mxGeometry x="3436" y="350" width="400" height="1050" as="geometry"/>
        </mxCell>
      </root>
    </mxGraphModel>
  </diagram>
