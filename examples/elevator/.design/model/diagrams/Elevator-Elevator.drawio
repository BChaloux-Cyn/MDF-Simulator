                <mxCell id="elevator:state:Elevator:__initial__" value="" style="ellipse;whiteSpace=wrap;html=1;aspect=fixed;fillColor=#000000;strokeColor=#000000;" parent="1" vertex="1">
                    <mxGeometry x="650" y="1940" width="20" height="20" as="geometry"/>
                </mxCell>
                <mxCell id="elevator:state:Elevator:Idle" value="Idle" style="rounded=1;whiteSpace=wrap;html=1;arcSize=10;fontFamily=Courier New;" parent="1" vertex="1">
