        <mxCell id="elevator:trans:Elevator:Floor_Updating:At_Destination:3" value="elevator:trans:Elevator:Floor_Updating:At_Destination:3&lt;br&gt;At_Destination()" style="edgeStyle=orthogonalEdgeStyle;html=1;labelBackgroundColor=none;exitX=0.0;exitY=0.25;exitDx=0;exitDy=0;entryX=0.6667;entryY=1.0;entryDx=0;entryDy=0;" edge="1" source="elevator:state:Elevator:Floor_Updating" target="elevator:state:Elevator:Arriving" parent="1">
          <mxGeometry x="-0.3" y="-15" relative="1" as="geometry"/>
