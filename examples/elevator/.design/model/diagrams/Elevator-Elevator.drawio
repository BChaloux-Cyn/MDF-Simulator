        <mxCell id="elevator:trans:Elevator:Floor_Updating:Continue:4" value="elevator:trans:Elevator:Floor_Updating:Continue:4&lt;br&gt;Continue()" style="edgeStyle=orthogonalEdgeStyle;html=1;labelBackgroundColor=none;exitX=0.0;exitY=0.75;exitDx=0;exitDy=0;entryX=1.0;entryY=0.6667;entryDx=0;entryDy=0;" edge="1" source="elevator:state:Elevator:Floor_Updating" target="elevator:state:Elevator:Moving" parent="1">
          <mxGeometry x="-0.3" y="-15" relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="elevator:trans:Elevator:Arriving:Arrived:5" value="elevator:trans:Elevator:Arriving:Arrived:5&lt;br&gt;Arrived()" style="edgeStyle=orthogonalEdgeStyle;html=1;labelBackgroundColor=none;exitX=0.3333;exitY=1.0;exitDx=0;exitDy=0;entryX=1.0;entryY=0.3333;entryDx=0;entryDy=0;" edge="1" source="elevator:state:Elevator:Arriving" target="elevator:state:Elevator:Exchanging" parent="1">
          <mxGeometry x="-0.3" y="-15" relative="1" as="geometry"/>
        </mxCell>
