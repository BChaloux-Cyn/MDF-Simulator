        <mxCell id="elevator:state:Elevator:Moving" value="Moving" style="rounded=1;whiteSpace=wrap;html=1;arcSize=10;fontFamily=Courier New;" vertex="1" parent="1">
          <mxGeometry x="1886" y="2230" width="160" height="50" as="geometry"/>
        </mxCell>
        <mxCell id="elevator:state:Elevator:Floor_Updating" value="Floor_Updating&lt;br&gt;──────────────────&lt;br&gt;&lt;i&gt;entry /&lt;/i&gt;&lt;br&gt;self.current_floor = rcvd_evt.floor_num;&lt;br&gt;if (self.current_floor == self.next_stop_floor) {&lt;br&gt;    generate At_Destination to self;&lt;br&gt;} else {&lt;br&gt;    generate Continue to self;&lt;br&gt;}&lt;br&gt;" style="rounded=1;whiteSpace=wrap;html=1;arcSize=10;fontFamily=Courier New;" vertex="1" parent="1">
          <mxGeometry x="955" y="2370" width="352" height="200" as="geometry"/>
        </mxCell>
        <mxCell id="elevator:state:Elevator:Arriving" value="Arriving&lt;br&gt;──────────────────&lt;br&gt;&lt;i&gt;entry /&lt;/i&gt;&lt;br&gt;self.direction = None;&lt;br&gt;&lt;br&gt;// Default: no further work — stay at current floor (triggers Idle path)&lt;br&gt;self.next_stop_floor = self.current_floor;&lt;br&gt;&lt;br&gt;// Check for lit DestFloorButtons at other floors&lt;br&gt;for (DestFloorButton btn : self-&amp;gt;R4) {&lt;br&gt;    if (btn.curr_state == &amp;quot;Lit&amp;quot;) {&lt;br&gt;        Floor dest_floor = btn-&amp;gt;R5;&lt;br&gt;        self.next_stop_floor = dest_floor.floor_num;&lt;br&gt;    }&lt;br&gt;}&lt;br&gt;&lt;br&gt;generate Arrived to self;&lt;br&gt;" style="rounded=1;whiteSpace=wrap;html=1;arcSize=10;fontFamily=Courier New;" vertex="1" parent="1">
          <mxGeometry x="120" y="1106" width="518" height="360" as="geometry"/>
        </mxCell>
        <mxCell id="elevator:state:Elevator:Exchanging" value="Exchanging&lt;br&gt;──────────────────&lt;br&gt;&lt;i&gt;entry /&lt;/i&gt;&lt;br&gt;// Notify any lit DestFloorButtons at the current floor&lt;br&gt;Set&amp;lt;DestFloorButton&amp;gt; dest_buttons = select many related by self-&amp;gt;R4&lt;br&gt;    where [] |btn: DestFloorButton| -&amp;gt; Boolean {&lt;br&gt;        return btn.curr_state == &amp;quot;Lit&amp;quot;;&lt;br&gt;    };&lt;br&gt;generate Floor_served to dest_buttons;&lt;br&gt;&lt;br&gt;// Notify lit FloorCallButtons at the current floor&lt;br&gt;Set&amp;lt;ShaftFloor&amp;gt; shaft_floors = select many related by self-&amp;gt;R1-&amp;gt;R2;&lt;br&gt;for (ShaftFloor sf : shaft_floors) {&lt;br&gt;    Floor floor = sf-&amp;gt;R3;&lt;br&gt;    Set&amp;lt;FloorCallButton&amp;gt; call_buttons = select many related by floor-&amp;gt;R6&lt;br&gt;        where [] |btn: FloorCallButton| -&amp;gt; Boolean {&lt;br&gt;            return btn.curr_state == &amp;quot;Lit&amp;quot;;&lt;br&gt;        };&lt;br&gt;    generate Call_served to call_buttons;&lt;br&gt;}&lt;br&gt;&lt;br&gt;// Open the car door — it will open the paired shaft door&lt;br&gt;CarDoor car_door = self-&amp;gt;R7;&lt;br&gt;generate Open_cmd to car_door;&lt;br&gt;" style="rounded=1;whiteSpace=wrap;html=1;arcSize=10;fontFamily=Courier New;" vertex="1" parent="1">
          <mxGeometry x="1774" y="120" width="518" height="500" as="geometry"/>
        </mxCell>
