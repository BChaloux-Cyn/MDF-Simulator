        <mxCell id="elevator:trans:Elevator:Moving:Floor_reached:2" value="elevator:trans:Elevator:Moving:Floor_reached:2&lt;br&gt;Floor_reached(floor_num: FloorNumber)" style="edgeStyle=orthogonalEdgeStyle;html=1;labelBackgroundColor=none;exitX=1.0;exitY=0.3333;exitDx=0;exitDy=0;entryX=0.0;entryY=0.5;entryDx=0;entryDy=0;" edge="1" source="elevator:state:Elevator:Moving" target="elevator:state:Elevator:Floor_Updating" parent="1">
          <mxGeometry x="-0.3" y="-15" relative="1" as="geometry"/>
