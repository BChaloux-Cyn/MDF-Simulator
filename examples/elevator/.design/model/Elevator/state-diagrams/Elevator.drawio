<mxfile compressed="false" version="24.0.0"><diagram name="Page-1" id="page1"><mxGraphModel dx="1034" dy="546" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1500" pageHeight="1320" math="0" shadow="0"><root><mxCell id="0"/><mxCell id="1" parent="0"/><mxCell id="elevator:state:Elevator:__initial__" value="" style="ellipse;whiteSpace=wrap;html=1;aspect=fixed;fillColor=#000000;strokeColor=#000000;" vertex="1" parent="1"><mxGeometry x="885" y="120" width="20" height="20" as="geometry"/></mxCell><mxCell id="elevator:state:Elevator:Idle" value="Idle&lt;br&gt;──────────────────&lt;br&gt;&lt;i&gt;entry /&lt;/i&gt;&lt;br&gt;self.direction = Stopped; self.next_stop_floor = 0; select any req from instances of Request where r2_elevator_id == self.elevator_id; if req != empty; generate Request_assigned to SELF; else; generate Elevator_available to Dispatcher; end if;" style="rounded=1;whiteSpace=wrap;html=1;arcSize=10;" vertex="1" parent="1"><mxGeometry x="885" y="390" width="160" height="96" as="geometry"/></mxCell><mxCell id="elevator:state:Elevator:Moving_Up" value="Moving_Up&lt;br&gt;──────────────────&lt;br&gt;&lt;i&gt;entry /&lt;/i&gt;&lt;br&gt;self.direction = Up;" style="rounded=1;whiteSpace=wrap;html=1;arcSize=10;" vertex="1" parent="1"><mxGeometry x="480" y="660" width="160" height="96" as="geometry"/></mxCell><mxCell id="elevator:state:Elevator:Moving_Down" value="Moving_Down&lt;br&gt;──────────────────&lt;br&gt;&lt;i&gt;entry /&lt;/i&gt;&lt;br&gt;self.direction = Down;" style="rounded=1;whiteSpace=wrap;html=1;arcSize=10;" vertex="1" parent="1"><mxGeometry x="750" y="660" width="160" height="96" as="geometry"/></mxCell><mxCell id="elevator:state:Elevator:Stopping" value="Stopping&lt;br&gt;──────────────────&lt;br&gt;&lt;i&gt;entry /&lt;/i&gt;&lt;br&gt;self.direction = Stopped;" style="rounded=1;whiteSpace=wrap;html=1;arcSize=10;" vertex="1" parent="1"><mxGeometry x="615" y="930" width="160" height="96" as="geometry"/></mxCell><mxCell id="elevator:state:Elevator:At_Floor" value="At_Floor&lt;br&gt;──────────────────&lt;br&gt;&lt;i&gt;entry /&lt;/i&gt;&lt;br&gt;select any next_req from instances of Request where request_id == self.r_queue_head_id; if next_req != empty;&lt;br&gt;  if next_req.destination_floor &gt; self.current_floor; self.next_direction = Up; end if;&lt;br&gt;  if next_req.destination_floor &lt; self.current_floor; self.next_direction = Down; end if;&lt;br&gt;else;&lt;br&gt;  select any fc from instances of FloorCall where floor_num == self.current_floor;&lt;br&gt;  if fc != empty; self.next_direction = fc.direction;&lt;br&gt;  else; self.next_direction = Stopped; end if;&lt;br&gt;end if; select any indicator from instances of FloorIndicator where r10_elevator_id == self.elevator_id and r10_floor_num == self.current_floor; generate Direction_set to indicator; generate Elevator_arrived to Floor; generate Open_door to SELF;" style="rounded=1;whiteSpace=wrap;html=1;arcSize=10;" vertex="1" parent="1"><mxGeometry x="1020" y="1200" width="160" height="236" as="geometry"/></mxCell><mxCell id="elevator:trans:Elevator:__initial__:__init__:0" value="" style="edgeStyle=orthogonalEdgeStyle;html=1;exitX=0.5;exitY=1.0;exitDx=0;exitDy=0;entryX=0.5;entryY=0.0;entryDx=0;entryDy=0;" edge="1" source="elevator:state:Elevator:__initial__" target="elevator:state:Elevator:Idle" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell><mxCell id="elevator:trans:Elevator:Idle:Request_assigned:0" value="elevator:trans:Elevator:Idle:Request_assigned:0&lt;br&gt;Request_assigned(target_floor: FloorNumber)&lt;br&gt;[target_floor &gt; current_floor]" style="edgeStyle=orthogonalEdgeStyle;html=1;exitX=0.0;exitY=0.5;exitDx=0;exitDy=0;entryX=1.0;entryY=0.5;entryDx=0;entryDy=0;" edge="1" source="elevator:state:Elevator:Idle" target="elevator:state:Elevator:Moving_Up" parent="1"><mxGeometry x="-0.3" y="-15" relative="1" as="geometry"/></mxCell><mxCell id="elevator:trans:Elevator:Idle:Request_assigned:1" value="elevator:trans:Elevator:Idle:Request_assigned:1&lt;br&gt;Request_assigned(target_floor: FloorNumber)&lt;br&gt;[target_floor &lt; current_floor]" style="edgeStyle=orthogonalEdgeStyle;html=1;exitX=0.3333;exitY=1.0;exitDx=0;exitDy=0;entryX=0.5;entryY=0.0;entryDx=0;entryDy=0;" edge="1" source="elevator:state:Elevator:Idle" target="elevator:state:Elevator:Moving_Down" parent="1"><mxGeometry x="-0.3" y="-15" relative="1" as="geometry"/></mxCell><mxCell id="elevator:trans:Elevator:Idle:Request_assigned:2" value="elevator:trans:Elevator:Idle:Request_assigned:2&lt;br&gt;Request_assigned(target_floor: FloorNumber)&lt;br&gt;[target_floor == current_floor]" style="edgeStyle=orthogonalEdgeStyle;html=1;exitX=0.6667;exitY=1.0;exitDx=0;exitDy=0;entryX=0.5;entryY=0.0;entryDx=0;entryDy=0;" edge="1" source="elevator:state:Elevator:Idle" target="elevator:state:Elevator:At_Floor" parent="1"><mxGeometry x="-0.3" y="-15" relative="1" as="geometry"/></mxCell><mxCell id="elevator:trans:Elevator:Moving_Up:Floor_reached:3" value="elevator:trans:Elevator:Moving_Up:Floor_reached:3&lt;br&gt;Floor_reached(current_floor: FloorNumber)&lt;br&gt;[current_floor == next_stop_floor]" style="edgeStyle=orthogonalEdgeStyle;html=1;exitX=0.5;exitY=1.0;exitDx=0;exitDy=0;entryX=0.3333;entryY=0.0;entryDx=0;entryDy=0;" edge="1" source="elevator:state:Elevator:Moving_Up" target="elevator:state:Elevator:Stopping" parent="1"><mxGeometry x="-0.3" y="-15" relative="1" as="geometry"/></mxCell><mxCell id="elevator:trans:Elevator:Moving_Up:Floor_reached:4" value="elevator:trans:Elevator:Moving_Up:Floor_reached:4&lt;br&gt;Floor_reached(current_floor: FloorNumber)&lt;br&gt;[current_floor != next_stop_floor]" style="edgeStyle=orthogonalEdgeStyle;html=1;exitX=0.2;exitY=0.0;exitDx=0;exitDy=0;entryX=0.0;entryY=0.2;entryDx=0;entryDy=0;" edge="1" source="elevator:state:Elevator:Moving_Up" target="elevator:state:Elevator:Moving_Up" parent="1"><mxGeometry x="-0.3" y="-15" relative="1" as="geometry"><A