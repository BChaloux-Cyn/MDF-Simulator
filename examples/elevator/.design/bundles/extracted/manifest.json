        "Lit": "// If the elevator is idle, wake it up\nFloor floor = self->R6;\nOptional<ShaftFloor> sf = select any related by floor->R3;\nif (sf.has_value()) {\n    ShaftFloor shaft_floor = sf.value();\n    Elevator elev = shaft_floor->R2->R1;\n    if (elev.curr_state == Idle) {\n        generate Floor_assigned(floor_num: floor.floor_num) to elev;\n    }\n}\n"
      },
