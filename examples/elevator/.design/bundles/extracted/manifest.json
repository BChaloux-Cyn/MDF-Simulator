    "CarDoor": {
      "attributes": {
        "door_id": {
          "identifier": [
            1
          ],
          "name": "door_id",
          "referential": null,
          "scope": "instance",
          "type": "UniqueID",
          "visibility": "private"
        }
      },
      "entry_actions": {
        "Closed": "Elevator elev = self->R7;\ngenerate Door_closed to elev;\n",
        "Closing": "// Tell the paired ShaftDoor to close \u2014 it will report back when done\nElevator elev = self->R7;\nSet<ShaftFloor> shaft_floors = select many related by elev->R1->R2;\nSet<ShaftFloor> current_sf = shaft_floors.filter(\n    [elev.current_floor] |s: ShaftFloor| -> Boolean {\n        Floor f = s->R3;\n        return f.floor_num == elev.current_floor;\n    });\nShaftFloor sf = current_sf.peek_front();\nShaftDoor sd = sf->R8;\ngenerate Close_cmd to sd;\n",
        "Open": "generate Close_cmd to self delay duration_s(5);\n",
        "Opening": "// Tell the paired ShaftDoor to open \u2014 it will report back when done\nElevator elev = self->R7;\nSet<ShaftFloor> shaft_floors = select many related by elev->R1->R2;\nSet<ShaftFloor> current_sf = shaft_floors.filter(\n    [elev.current_floor] |s: ShaftFloor| -> Boolean {\n        Floor f = s->R3;\n        return f.floor_num == elev.current_floor;\n    });\nShaftFloor sf = current_sf.peek_front();\nShaftDoor sd = sf->R8;\ngenerate Open_cmd to sd;\n"
      },
      "final_states": [],
