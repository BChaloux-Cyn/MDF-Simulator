        "next_stop_floor": {
          "identifier": null,
          "name": "next_stop_floor",
          "referential": null,
          "scope": "instance",
          "type": "FloorNumber",
          "visibility": "private"
        }
      },
      "entry_actions": {
        "Arriving": "Direction prev_direction = self.direction;\nself.direction = None;\n\n// Find lit DestFloorButtons (excluding current floor)\nSet<DestFloorButton> lit_btns = self._get_lit_buttons();\n\nif (lit_btns.is_empty()) {\n    // No destination buttons \u2014 check for lit FloorCallButtons\n    Set<ShaftFloor> shaft_floors = select many related by self->R1->R2;\n    Set<FloorCallButton> lit_calls = shaft_floors.flat_map(\n        [] |sf: ShaftFloor| -> Set<FloorCallButton> {\n            Floor f = sf->R3;\n            return select many related by f->R6\n                where [] |btn: FloorCallButton| -> Boolean {\n                    return btn.curr_state == Lit;\n                };\n        });\n\n    if (lit_calls.is_empty()) {\n        // No work at all \u2014 go Idle when door closes\n        self.next_stop_floor = self.current_floor;\n        generate Arrived to self;\n        return;\n    }\n\n    // Pick the earliest pressed FloorCallButton\n    List<FloorCallButton> sorted_calls = lit_calls.sort(\n        [] |a: FloorCallButton, b: FloorCallButton| -> Boolean {\n            return a.pressed_at < b.pressed_at;\n        });\n    FloorCallButton earliest = sorted_calls.peek_front();\n    Floor target_floor = earliest->R6;\n    self.next_stop_floor = target_floor.floor_num;\n    generate Arrived to self;\n    return;\n}\n\nself.next_stop_floor = self._pick_next_stop(lit_btns, prev_direction);\ngenerate Arrived to self;\n",
        "Departing": "self.next_stop_floor = rcvd_evt.floor_num;\nif (self.next_stop_floor > self.current_floor) {\n    self.direction = Up;\n} else {\n    self.direction = Down;\n}\ngenerate Ready to self;\n",
        "Exchanging": "self.next_stop_floor = rcvd_evt.floor_num;\n// Find the specific DestFloorButton for the current floor and notify it\nSet<DestFloorButton> dest_buttons = select many related by self->R4\n    where [self.current_floor] |btn: DestFloorButton| -> Boolean {\n        Floor f = btn->R5;\n        return btn.curr_state == Lit and f.floor_num == self.current_floor;\n    };\ngenerate Floor_served to dest_buttons;\n\n// Notify FloorCallButtons at current floor \u2014 transitions Lit->Idle\nSet<ShaftFloor> shaft_floors = select many related by self->R1->R2;\nSet<ShaftFloor> current_sf = shaft_floors.filter(\n    [self.current_floor] |s: ShaftFloor| -> Boolean {\n        Floor f = s->R3;\n        return f.floor_num == self.current_floor;\n    });\nShaftFloor sf = current_sf.peek_front();\nFloor floor = sf->R3;\nSet<FloorCallButton> call_buttons = select many related by floor->R6\n    where [] |btn: FloorCallButton| -> Boolean {\n        return btn.curr_state == Lit;\n    };\ngenerate Call_served to call_buttons;\n\n// Open the car door \u2014 it will open the paired shaft door\nCarDoor car_door = self->R7;\ngenerate Open_cmd to car_door;\n",
        "Floor_Updating": "self.current_floor = rcvd_evt.floor_num;\nif (self.current_floor == self.next_stop_floor) {\n    generate At_Destination to self;\n} else {\n    generate Continue to self;\n}\n",
        "Idle": null,
        "Moving": null
      },
      "final_states": [
        "Idle",
        "Moving"
      ],
